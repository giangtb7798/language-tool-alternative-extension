{
  "manifest_version": 3,
  "name": "Grammar Checker Alternative",
  "version": "9.0.0",
  "description": "Grammar checker, rewriter, tone detector & translator using OpenAI or any OpenAI-compatible LLM",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "sidePanel",
    "clipboardRead",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.languagetool.org/*",
    "https://api.groq.com/*",
    "https://openrouter.ai/*",
    "https://api.together.xyz/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Grammar Checker"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "commands": {
    "check-grammar": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "Check grammar of selected text"
    },
    "fix-all": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Fix all grammar errors in active field"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/grammar-core.js", "content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
